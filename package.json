{
  "name": "skilltap-monorepo",
  "private": true,
  "workspaces": ["packages/*", "website"],
  "scripts": {
    "dev": "bun run --bun packages/cli/src/index.ts",
    "test": "bun test --recursive packages/",
    "build": "bun build packages/cli/src/index.ts --compile --outfile skilltap",
    "lint": "biome lint packages/",
    "format": "biome format --write packages/",
    "check": "biome check --write packages/",
    "bench": "bun run packages/core/src/benchmarks/scan.bench.ts",
    "bump": "bun scripts/bump-version.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "bun-types": "^1.3.10"
  },
  "patchedDependencies": {
    "@sigstore/core@3.1.0": "patches/@sigstore%2Fcore@3.1.0.patch",
    "@tufjs/models@4.1.0": "patches/@tufjs%2Fmodels@4.1.0.patch"
  }
}
