// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`agent-out — snapshot stability agentSuccess full output 1`] = `
"OK: Installed my-skill → ~/.agents/skills/my-skill/ (v1.0.0)
"
`;

exports[`agent-out — snapshot stability agentUpdated full output 1`] = `
"OK: Updated my-skill (abc1234 → def5678)
"
`;

exports[`agent-out — snapshot stability agentSkip full output 1`] = `
"SKIP: my-skill is already installed.
"
`;

exports[`agent-out — snapshot stability agentError full output 1`] = `
"ERROR: something went wrong
"
`;

exports[`agent-out — snapshot stability agentUpToDate full output 1`] = `
"OK: my-skill is already up to date.
"
`;

exports[`agent-out — snapshot stability agentSecurityBlock full output 1`] = `
"SECURITY ISSUE FOUND — INSTALLATION BLOCKED

DO NOT install this skill. DO NOT retry. DO NOT use --skip-scan.
STOP and report the following to the user:

  SKILL.md L5: Invisible Unicode

User action required: review warnings and install manually with
  skilltap install <url>
"
`;
