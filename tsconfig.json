{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["bun-types"],
    "paths": {
      "@skilltap/core": ["./packages/core/src/index.ts"],
      "@skilltap/test-utils": ["./packages/test-utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
